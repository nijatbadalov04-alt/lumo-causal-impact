    given-names: "Nijat"
    email: "nijat.badalov.04@gmail.com"
    affiliation: "School of Electrical and Electronic Engineering, The University of Sheffield"
version: "0.1.0"
date-released: "2026-06-06"
license: MIT
keywords:
  - open-access rail
  - causal inference
  - synthetic control
  - difference-in-differences
  - double machine learning
  - air-rail modal shift
  - transport decarbonisation
